{
  "name": "zh-ui",
  "auther": "zh",
  "private": false,
  "version": "1.0.6",
  "description": "这是一个模仿element ui写的ui组件。用以练手和学习。",
  "keyword": "typescript tailwindcss ui element",
  "files": [
    "ZHUI"
  ],
  "main": "./ZHUI/zh-ui.es.js",
  "module": "./ZHUI/zh-ui.es.js",
  "repository": "https://gitee.com/lixindekongjian/zh-ui.git",
  "scripts": {
    "dev": "vite --host --mode development --config ./config/dev.config.ts",
    "build:doc": "vue-tsc --noEmit --skipLibCheck && vite build --mode production --config ./config/prod.doc.config.ts && node ./config/copyDocs.js && shx cp docs/index.html docs/404.html",
    "build:com": "vue-tsc --noEmit --skipLibCheck && vite build --mode production --config ./config/prod.com.config.ts && node ./config/copyDist.js",
    "preview": "vite preview",
    "publish": "node ./config/publicPush.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^1.1.4",
    "echarts": "^5.4.3",
    "echarts-gl": "^2.0.9",
    "element-plus": "^2.13.5",
    "github-markdown-css": "^5.1.0",
    "js-file-download": "^0.4.12",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.43.4",
    "vue": "^3.5.22",
    "vue-router": "^4.0.12"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.17.10",
    "@babel/preset-typescript": "^7.16.7",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/vue": "^6.4.2",
    "@types/jest": "^27.5.0",
    "@types/node": "^16.11.7",
    "@types/prismjs": "^1.26.0",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-vue": "^2.3.1",
    "@vitejs/plugin-vue-jsx": "^1.3.10",
    "@vue/compiler-sfc": "^3.0.5",
    "@vue/test-utils": "^2.0.0-rc.18",
    "@vueuse/core": "12.0.0",
    "autoprefixer": "^10.2.6",
    "babel-jest": "^26.6.3",
    "copy-dir": "^1.3.0",
    "eslint": "^8.2.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vue": "^8.1.1",
    "jest": "^26.6.3",
    "jest-environment-jsdom": "^26.6.2",
    "markdown-it-anchor": "^8.6.3",
    "postcss": "^8.3.0",
